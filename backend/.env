# =====================================================
# AuditAI .env — FREE STACK
# Get a free Gemini key: https://aistudio.google.com/apikey
# Embeddings run LOCALLY via sentence-transformers (no key needed)
# =====================================================

# Google Gemini API (free tier: 1,500 requests/day)
GEMINI_API_KEY=AIzaSyC6fms3EElxSJXmIP6qhHt5f60xkKLiqD8

# PostgreSQL Database (must have pgvector extension installed)
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PG_PASSWORD@localhost:5432/auditai_db
DATABASE_URL=postgresql+asyncpg://postgres:auditai_pass@localhost:5432/auditai_db

# JWT Authentication
JWT_SECRET_KEY=a-very-long-random-secret-string-minimum-32-characters
JWT_EXPIRE_HOURS=8

# Initial Admin Account (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=25
UPLOAD_DIR=uploads

# Models (defaults are fine for the free stack)
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- Optional paid fallbacks (leave blank unless you switch providers) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
