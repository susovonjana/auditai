# =====================================================
# AuditAI .env — FREE STACK
# Get a free Gemini key: https://aistudio.google.com/apikey
# Embeddings run LOCALLY via sentence-transformers (no key needed)
# =====================================================

# Google Gemini API (free tier: 1,500 requests/day)
GEMINI_API_KEY=paste-your-free-gemini-key-here

# PostgreSQL Database (must have pgvector extension installed)
# Local dev: point at a local Postgres or the docker-compose `auditai-pg` container.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PG_PASSWORD@localhost:5432/auditai_db
# Amazon RDS / Aurora example (note the asyncpg driver + no sslmode in the URL):
# DATABASE_URL=postgresql+asyncpg://prod_aura:YOUR_DB_PASSWORD@one-audit-aura-instance-1.cjwpxsh7zcyc.eu-west-1.rds.amazonaws.com:5432/aura

# --- Database TLS (Amazon RDS / Aurora) ---
# Leave DB_SSLMODE empty (or "disable") for a local non-TLS Postgres.
# For RDS use "verify-full" with the AWS global CA bundle. Download it once:
#   curl -o global-bundle.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# DB_SSLMODE=verify-full
# DB_SSL_ROOT_CERT=./global-bundle.pem

# --- Production DB (set in ECS task definition / Secrets Manager — DO NOT commit) ---
# DATABASE_URL=postgresql+asyncpg://prod_aura:FROM_SECRETS_MANAGER@one-audit-aura.cluster-cjwpxsh7zcyc.eu-west-1.rds.amazonaws.com:5432/aura
# DB_SSL_MODE=verify-full
# DB_SSL_ROOT_CERT=/etc/ssl/certs/rds-global-bundle.pem   # baked into the image

# JWT Authentication
JWT_SECRET_KEY=a-very-long-random-secret-string-minimum-32-characters
JWT_EXPIRE_HOURS=8

# Initial Admin Account (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=25
UPLOAD_DIR=uploads

# Models (defaults are fine for the free stack)
GEMINI_MODEL=gemini-2.0-flash
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- Security: file encryption at rest ---
# Generate a real key for production with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_UPLOADS=true
FILE_ENCRYPTION_KEY=

# --- Security: rate limits (slowapi syntax) ---
RATE_LIMIT_ASK=30/hour;200/day
RATE_LIMIT_SESSION_START=10/minute
RATE_LIMIT_ADMIN_LOGIN=5/minute;30/hour
RATE_LIMIT_ADMIN_UPLOAD=20/hour

# --- Security: per-session daily question cap ---
MAX_QUESTIONS_PER_SESSION_DAY=100
MAX_QUESTION_CHARS=4000

# --- Tesseract OCR (only needed for image / scanned-PDF uploads) ---
# The backend auto-detects standard install paths. Only set this if
# Tesseract is installed somewhere unusual.
# Example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Optional paid fallbacks (leave blank unless you switch providers) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
